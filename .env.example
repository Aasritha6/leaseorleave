# Gemini Developer API key — https://aistudio.google.com/apikey
# This is the ONLY LLM provider used anywhere in this app.
GEMINI_API_KEY=

# Optional: override the model. Defaults to gemini-2.5-flash if unset.
# Other current options as of June 2026: gemini-3-flash, gemini-3.5-flash (preview/GA
# availability varies by account — check https://ai.google.dev/gemini-api/docs/models).
GEMINI_MODEL=gemini-2.5-flash

# Anakin API key — https://anakin.io/signup?redirect=/wire
# Powers both Wire (pre-built actions for Reddit/Airbnb) and the generic
# URL Scraper + Search API used for everything else (NoBroker, MagicBricks, etc).
# Free tier is 500 credits with no card required as of when this was written —
# verify current limits at https://anakin.io/pricing.
ANAKIN_API_KEY=
